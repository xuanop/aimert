-- 智能部位檢測
local function getBestTargetPart(char)
    if AimbotTargetPart ~= "Auto" then return AimbotTargetPart end
    if not char then return "Head" end
    local priority = {"Head", "UpperTorso", "HumanoidRootPart", "LowerTorso"}
    for _, name in ipairs(priority) do
        if char:FindFirstChild(name) then return name end
    end
    return "Head"
end

-- 自瞄目標尋找
local function findAimbotTarget()
    local closestPlayer = nil
    local closestDist = AimbotFOV
    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    local now = tick()
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        if AimbotTeamCheck and player.Team == LocalPlayer.Team then continue end
        local char = player.Character
        if not char then continue end
        local humanoid = char:FindFirstChild("Humanoid")
        if not humanoid or humanoid.Health <= 0 then continue end
        local partName = getBestTargetPart(char)
        local targetPart = char:FindFirstChild(partName)
        if not targetPart then continue end
        local pos = targetPart.Position
        local data = TargetData[player] or {pos = pos, time = now, velocity = Vector3.zero}
        local dt = now - data.time
        if dt > 0 then data.velocity = (pos - data.pos) / dt end
        data.pos = pos; data.time = now; TargetData[player] = data
        if AimbotWallCheck then
            local myHead = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Head")
            if myHead then
                local rayParams = RaycastParams.new()
                rayParams.FilterDescendantsInstances = {LocalPlayer.Character, char}
                rayParams.FilterType = Enum.RaycastFilterType.Blacklist
                local toTarget = pos - myHead.Position
                local distToTarget = toTarget.Magnitude
                if distToTarget > 0 and Workspace:Raycast(myHead.Position, toTarget.Unit * (distToTarget + 1), rayParams) then continue end
            end
        end
        local camPos = Camera.CFrame.Position
        local distance = (pos - camPos).Magnitude
        if distance > AimbotMaxDistance then continue end
        local screenPos, onScreen = Camera:WorldToViewportPoint(pos)
        if not onScreen then continue end
        local dist = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
        if dist < closestDist then closestDist = dist; closestPlayer = player end
    end
    if closestPlayer then
        local char = closestPlayer.Character
        local partName = getBestTargetPart(char)
        local targetPart = char:FindFirstChild(partName)
        if targetPart then
            local aimPos = targetPart.Position
            if AIAssist then
                local data = TargetData[closestPlayer]
                if data and data.velocity.Magnitude > 0.5 then
                    aimPos = aimPos + data.velocity * PredictionTime
                end
            end
            return closestPlayer, aimPos
        end
    end
    return nil, nil
end

