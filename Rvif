local function logDetection(text)
    table.insert(AntiAntiCheat.Log, os.date("%H:%M:%S") .. " | " .. text)
    if #AntiAntiCheat.Log > 50 then table.remove(AntiAntiCheat.Log, 1) end
    print("[AntiAntiCheat] " .. text)
    if AntiAntiCheat.ShowNotifications then
        pcall(function()
            Rayfield:Notify({Title = "🔍 反作弊侦察", Content = text, Duration = 3, Image = 4483362458})
        end)
    end
end

local function scanForAntiCheat()
    if not AntiAntiCheat.Enabled then return end
    AntiAntiCheat.DetectedAC = {}
    local startTime = tick()
    pcall(function()
        local placesToScan = { Workspace, ReplicatedStorage, game:GetService("ServerStorage") }
        for _, container in ipairs(placesToScan) do
            for _, name in ipairs(KnownAntiCheats) do
                for _, obj in ipairs(container:GetChildren()) do
                    if obj.Name:find(name) then
                        logDetection("檢測到: " .. obj.Name .. " (" .. container.Name .. ")")
                    end
                end
            end
        end
    end)
    logDetection("輕量掃描完成 (" .. math.floor((tick() - startTime)*1000) .. "ms)")
end

