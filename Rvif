    if esp then for _,d in pairs(esp) do pcall(function() d:Remove() end) end; ESPObjects[player]=nil end
end

local function clearAllESP()
    for player,esp in pairs(ESPObjects) do
        if esp then for _,d in pairs(esp) do pcall(function() if d then d:Remove() end end) end end
    end
    ESPObjects = {}
end

local function updateESP(player, esp)
    local char = player.Character
    if not char then for _,d in pairs(esp) do if d then d.Visible=false end end; esp.aimScreenPos=nil; return end
    local humanoid = char:FindFirstChild("Humanoid"); local head = char:FindFirstChild("Head"); local root = char:FindFirstChild("HumanoidRootPart")
    if not humanoid or humanoid.Health<=0 or not head or not root then for _,d in pairs(esp) do if d then d.Visible=false end end; esp.aimScreenPos=nil; return end
    if ESPTeamCheck and player.Team==LocalPlayer.Team then for _,d in pairs(esp) do if d then d.Visible=false end end; esp.aimScreenPos=nil; return end
    local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    local dist = myRoot and (root.Position - myRoot.Position).Magnitude or 0
    if dist > ESPMaxDistance then for _,d in pairs(esp) do if d then d.Visible=false end end; esp.aimScreenPos=nil; return end
    local headPos, headOnScreen = Camera:WorldToViewportPoint(head.Position)
    local rootPos, rootOnScreen = Camera:WorldToViewportPoint(root.Position)
    if not headOnScreen and not rootOnScreen then for _,d in pairs(esp) do if d then d.Visible=false end end; esp.aimScreenPos=nil; return end
    local screenY = headOnScreen and headPos.Y or rootPos.Y; local screenX = rootOnScreen and rootPos.X or headPos.X
    local boxHeight=100; local boxWidth=50; local boxX=screenX - boxWidth/2; local boxY=screenY - boxHeight*0.1
    -- 绘制
    if esp.HealthBarBG and esp.HealthBar and ESPShowHealthBar then
        local barWidth=6; local barHeight=boxHeight; local hpRatio = humanoid.Health/humanoid.MaxHealth
        esp.HealthBarBG.Visible=true; esp.HealthBarBG.Position=Vector2.new(boxX - barWidth - 4, boxY); esp.HealthBarBG.Size=Vector2.new(barWidth, barHeight)
        esp.HealthBar.Visible=true; esp.HealthBar.Position=Vector2.new(boxX - barWidth - 4, boxY + barHeight*(1-hpRatio)); esp.HealthBar.Size=Vector2.new(barWidth, barHeight*hpRatio)
        esp.HealthBar.Color = hpRatio>0.5 and Color3.fromRGB(0,255,0) or (hpRatio>0.25 and Color3.fromRGB(255,255,0) or Color3.fromRGB(255,0,0))
    elseif esp.HealthBarBG then esp.HealthBarBG.Visible=false; if esp.HealthBar then esp.HealthBar.Visible=false end end
    if esp.Health and ESPShowHealth then
        esp.Health.Visible=true; local hp=math.floor(humanoid.Health); esp.Health.Position=Vector2.new(screenX, boxY+boxHeight+5); esp.Health.Text=hp.." HP"
        esp.Health.Color = hp/humanoid.MaxHealth>0.5 and Color3.fromRGB(0,255,0) or (hp/humanoid.MaxHealth>0.25 and Color3.fromRGB(255,255,0) or Color3.fromRGB(255,0,0))
    elseif esp.Health then esp.Health.Visible=false end
    if esp.Distance and ESPShowDistance then esp.Distance.Visible=true; esp.Distance.Position=Vector2.new(screenX, boxY+boxHeight+18); esp.Distance.Text=math.floor(dist).."m" elseif esp.Distance then esp.Distance.Visible=false end
    if esp.Box and ESPShowBox then esp.Box.Visible=true; esp.Box.Position=Vector2.new(boxX, boxY); esp.Box.Size=Vector2.new(boxWidth, boxHeight) elseif esp.Box then esp.Box.Visible=false end
    if esp.Name and ESPShowName then esp.Name.Visible=true; esp.Name.Position=Vector2.new(screenX, boxY-15); esp.Name.Text=player.Name elseif esp.Name then esp.Name.Visible=false end
    if esp.Weapon and ESPShowWeapon then
        esp.Weapon.Visible=true; local toolName=""
        for _,child in ipairs(char:GetChildren()) do if child:IsA("Tool") then toolName=child.Name; break end end
        esp.Weapon.Position=Vector2.new(screenX, boxY+boxHeight+30); esp.Weapon.Text=toolName
    elseif esp.Weapon then esp.Weapon.Visible=false end
    if esp.Tracer and ESPShowTracers then esp.Tracer.Visible=true; esp.Tracer.From=Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y); esp.Tracer.To=Vector2.new(screenX, boxY) elseif esp.Tracer then esp.Tracer.Visible=false end
    if esp.HeadDot and ESPShowHeadDot and headOnScreen then esp.HeadDot.Visible=true; esp.HeadDot.Position=Vector2.new(headPos.X, headPos.Y) elseif esp.HeadDot then esp.HeadDot.Visible=false end
    -- 储存瞄准坐标
    local aimPartName = getBestTargetPart(char)
    local aimPart = char:FindFirstChild(aimPartName)
    if aimPart then
        local aimPos, aimOnScreen = Camera:WorldToViewportPoint(aimPart.Position)
        if aimOnScreen then esp.aimScreenPos = Vector2.new(aimPos.X, aimPos.Y)
        else esp.aimScreenPos = nil end
    else esp.aimScreenPos = nil end
end

