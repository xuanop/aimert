-- ============ 運行循環 ============
local aimbotConnection = RunService.RenderStepped:Connect(function()
    if FOVCircle and FOVCircle.Visible then
        FOVCircle.Position = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    end
    if not AimbotEnabled then
        CurrentAimPos = nil
        return
    end
    local target, aimPos = findAimbotTarget()
    CurrentTarget = target
    CurrentAimPos = aimPos

    local shouldLock = false
    if AimMode == "Always" then
        shouldLock = true
    elseif AimMode == "LeftClick" then
        shouldLock = UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1)
    elseif AimMode == "RightClick" then
        shouldLock = UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2)
    end

    if shouldLock and CurrentAimPos then
        if AimMethod == "Camera" then
            local camPos = Camera.CFrame.Position
            local targetCF = CFrame.new(camPos, CurrentAimPos)
            if AimbotSmoothing >= 1 then
                Camera.CFrame = targetCF
            else
                Camera.CFrame = Camera.CFrame:Lerp(targetCF, AimbotSmoothing)
            end
        elseif AimMethod == "Rivals" then
            local screenPos, onScreen = Camera:WorldToViewportPoint(CurrentAimPos)
            if onScreen then
                local currentMouse = UserInputService:GetMouseLocation()
                local targetPos = Vector2.new(screenPos.X, screenPos.Y)
                local lerpAlpha = 1 - (math.clamp(AimbotSmoothing, 0, 0.9) * 0.9)
                local delta = (targetPos - currentMouse) * lerpAlpha
                mousemoverel(delta.X, delta.Y)
            end
        elseif AimMethod == "Mouse" then
            local aimScreenPos = nil
            if CurrentTarget and ESPObjects[CurrentTarget] then
                aimScreenPos = ESPObjects[CurrentTarget].aimScreenPos
            end
            if not aimScreenPos then
                local screenPos, onScreen = Camera:WorldToViewportPoint(CurrentAimPos)
                if onScreen then aimScreenPos = Vector2.new(screenPos.X, screenPos.Y) end
            end
            if aimScreenPos then
                pcall(function()
                    UserInputService:SetMouseLocation(math.floor(aimScreenPos.X), math.floor(aimScreenPos.Y))
                end)
            end
        end
    end
end)

local espConnection = RunService.RenderStepped:Connect(function()
    if not ESPEnabled then
