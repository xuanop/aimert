local function getValidPlayerNamesForFling()
    local names = {}
    for _, obj in ipairs(Workspace:GetChildren()) do
        if obj:IsA("Model") and obj.PrimaryPart ~= nil and obj.PrimaryPart.Name == "HumanoidRootPart" then
            if obj.Name ~= LocalPlayer.Name and obj.Name ~= "EffectLoader" then
                table.insert(names, obj.Name)
            end
        end
    end
    return names
end

local function getTargetRootForFling()
    if type(selectedTargetName) ~= "string" or selectedTargetName == "" then return nil end
    local targetModel = Workspace:FindFirstChild(selectedTargetName)
    return (targetModel and targetModel:IsA("Model")) and targetModel:FindFirstChild("HumanoidRootPart") or nil
end

local function getLocalRootForFling()
    local character = LocalPlayer.Character
    return character and character:FindFirstChild("HumanoidRootPart") or nil
end

local function startElevatorFling()
    if flingConnection then flingConnection:Disconnect() end
    flingConnection = RunService.Heartbeat:Connect(function()
        local myRoot, targetRoot = getLocalRootForFling(), getTargetRootForFling()
        local humanoid = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if myRoot and targetRoot and humanoid then
            humanoid.PlatformStand = true
            myRoot.CFrame = targetRoot.CFrame * CFrame.new(0, -1, 0)
            myRoot.AssemblyLinearVelocity = Vector3.new(0, 50000, 0)
            myRoot.AssemblyAngularVelocity = Vector3.new(50000, 50000, 50000)
        end
    end)
end

local function startStayingAtCenter()
    if stayingConnection then stayingConnection:Disconnect() end
    stayingConnection = RunService.Heartbeat:Connect(function()
        local lobby = Workspace:FindFirstChild("RegularLobby")
        local myHRP = getLocalRootForFling()
        if lobby and myHRP then
            local pos = (lobby:IsA("Model") and lobby.PrimaryPart) and lobby.PrimaryPart.Position or (lobby:IsA("BasePart") and lobby.Position)
            if pos then
                myHRP.CFrame = CFrame.new(pos + Vector3.new(0, 20, 0)) * myHRP.CFrame.Rotation
                myHRP.AssemblyLinearVelocity = Vector3.zero
                myHRP.AssemblyAngularVelocity = Vector3.zero
            end
        end
    end)
end

